\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-lg font-medium tracking-tight mb-4 text-white\",\"data-testid\":\"privacy-section-retention\",\"children\":\"Data retention\"}],[\"$\",\"p\",null,{\"style\":{\"color\":\"rgba(255,255,255,0.5)\"},\"children\":\"Memory facts are stored in Cloudflare KV and persist until you delete your account. Voice recordings are never stored. Conversation text exists only for the duration of your active browser session. Rate-limiting data and usage logs are retained temporarily for security purposes and automatically expire.\"}]]}]\n1a:[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-lg font-medium tracking-tight mb-4 text-white\",\"data-testid\":\"privacy-section-rights\",\"children\":\"Your rights\"}],[\"$\",\"p\",null,{\"style\":{\"color\":\"rgba(255,255,255,0.5)\"},\"children\":\"You can delete all of your data at any time by deleting your account. This removes your memory facts from Cloudflare KV and your profile from Clerk. If you need assistance with data deletion, contact us at the email below.\"}]]}]\n1b:[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-lg font-medium tracking-tight mb-4 text-white\",\"data-testid\":\"privacy-section-contact\",\"children\":\"Contact\"}],[\"$\",\"p\",null,{\"style\":{\"color\":\"rgba(255,255,255,0.5)\"},\"children\":[\"For any privacy-related questions or data requests, reach out to us at\",\" \",[\"$\",\"a\",null,{\"href\":\"mailto:rudrasatani@missi.space\",\"className\":\"text-white/70 underline underline-offset-4 decoration-white/20 hover:decoration-white/40 transition-colors\",\"data-testid\":\"privacy-contact-email\",\"children\":\"rudrasatani@missi.space\"}]]}]]}]\n1c:[\"$\",\"$L22\",null,{\"children\":[\"$L23\",[\"$\",\"$L24\",null,{\"promise\":\"$@25\"}]]}]\n1e:[[\"$\",\"meta\",\"0\",{\"charSet\":\"utf-8\"}],[\"$\",\"meta\",\"1\",{\"name\":\"viewport\",\"content\":\"width=device-width, initial-scale=1