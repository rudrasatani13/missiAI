{"type":"app","meta":{"headers":{"x-nextjs-stale-time":"300","x-nextjs-prerender":"1","x-next-cache-tags":"_N_T_/layout,_N_T_/(legal)/layout,_N_T_/(legal)/privacy/layout,_N_T_/(legal)/privacy/page,_N_T_/privacy"}},"html":"<!DOCTYPE html><!--dvJj856NW4NVgjhqpEA3s--><html lang=\"en\" class=\"dark\"><head><meta charSet=\"utf-8\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/><link rel=\"stylesheet\" href=\"/_next/static/css/6d41735a7f9a496e.css\" data-precedence=\"next\"/><link rel=\"preload\" as=\"script\" fetchPriority=\"low\" href=\"/_next/static/chunks/webpack-9d34c7dae023d6dc.js\"/><script src=\"/_next/static/chunks/b0cbb456-ccec192aeedaa34c.js\" async=\"\"></script><script src=\"/_next/static/chunks/2385-c4db6d0a79f7d8c7.js\" async=\"\"></script><script src=\"/_next/static/chunks/main-app-be5972b520003d4a.js\" async=\"\"></script><script src=\"/_next/static/chunks/6331-3bb9f5d3942f7e29.js\" async=\"\"></script><script src=\"/_next/static/chunks/2091-d7a598170f8c8af3.js\" async=\"\"></script><script src=\"/_next/static/chunks/4778-8df61705662411f2.js\" async=\"\"></script><script src=\"/_next/static/chunks/3018-b0c1fdbef98b950c.js\" async=\"\"></script><script src=\"/_next/static/chunks/1112-dd04eae3afe28e65.js\" async=\"\"></script><script src=\"/_next/static/chunks/app/layout-6d7dbccfe2b821af.js\" async=\"\"></script><script src=\"/_next/static/chunks/7708-194736aba611135d.js\" async=\"\"></script><script src=\"/_next/static/chunks/app/error-e8d89199668bf5c3.js\" async=\"\"></script><script src=\"/_next/static/chunks/app/(legal)/layout-97936c583f8d8941.js\" async=\"\"></script><script src=\"https://clerk.missi.space/npm/@clerk/clerk-js@5/dist/clerk.browser.js\" data-clerk-js-script=\"true\" async=\"\" crossorigin=\"anonymous\" data-clerk-publishable-key=\"pk_live_Y2xlcmsubWlzc2kuc3BhY2Uk\"></script><link rel=\"preconnect\" href=\"https://fonts.googleapis.com\"/><link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin=\"anonymous\"/><meta name=\"next-size-adjust\" content=\"\"/><title>Privacy Policy — missiAI</title><meta name=\"description\" content=\"How missiAI handles your data, voice recordings, and personal information.\"/><link rel=\"manifest\" href=\"/manifest.webmanifest\"/><meta name=\"mobile-web-app-capable\" content=\"yes\"/><meta name=\"apple-mobile-web-app-title\" content=\"missiAI\"/><meta name=\"apple-mobile-web-app-status-bar-style\" content=\"black-translucent\"/><meta property=\"og:title\" content=\"missiAI — AI with Memory\"/><meta property=\"og:description\" content=\"Voice AI assistant that remembers you. Chat naturally in Hindi, English, or Hinglish.\"/><meta property=\"og:url\" content=\"https://missi.space\"/><meta property=\"og:site_name\" content=\"missiAI\"/><meta property=\"og:type\" content=\"website\"/><meta name=\"twitter:card\" content=\"summary_large_image\"/><meta name=\"twitter:title\" content=\"missiAI — AI with Memory\"/><meta name=\"twitter:description\" content=\"Voice AI assistant that remembers you. Chat naturally in Hindi, English, or Hinglish.\"/><link rel=\"icon\" href=\"/favicon.ico\"/><link rel=\"icon\" href=\"/favicon.svg\" type=\"image/svg+xml\"/><link rel=\"icon\" href=\"/favicon-96x96.png\" sizes=\"96x96\" type=\"image/png\"/><link rel=\"apple-touch-icon\" href=\"/apple-touch-icon.png\"/><link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&amp;family=Space+Grotesk:wght@300;400;500;600;700&amp;family=Space+Mono:wght@400;700&amp;family=VT323&amp;display=swap\" rel=\"stylesheet\"/><script src=\"/_next/static/chunks/polyfills-42372ed130431b0a.js\" noModule=\"\"></script></head><body class=\"antialiased bg-black text-white\" style=\"background-color:#000000;color:#ffffff;font-family:&#x27;Inter&#x27;, system-ui, sans-serif\"><div hidden=\"\"><!--$--><!--/$--></div><div class=\"min-h-screen flex flex-col\"><div class=\"flex-1\"><!--$--><div class=\"min-h-screen bg-black text-white\"><nav class=\"flex items-center justify-between px-6 md:px-10 py-5 max-w-3xl mx-auto\"><a class=\"flex items-center gap-2 transition-opacity hover:opacity-70\" style=\"color:rgba(255,255,255,0.45)\" data-testid=\"legal-back-home\" href=\"/\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-arrow-left w-4 h-4\"><path d=\"m12 19-7-7 7-7\"></path><path d=\"M19 12H5\"></path></svg><span class=\"text-xs font-light tracking-wide\">Home</span></a><img alt=\"missiAI\" draggable=\"false\" loading=\"lazy\" width=\"28\" height=\"28\" decoding=\"async\" data-nimg=\"1\" class=\"w-6 h-6 opacity-40 pointer-events-none select-none\" style=\"color:transparent\" src=\"/missi-ai-logo.png\"/></nav><main class=\"max-w-3xl mx-auto px-6 md:px-10 pb-20\"><article class=\"prose-custom\" style=\"font-size:16px;line-height:1.85\"><div data-testid=\"privacy-policy-page\"><h1 class=\"text-3xl md:text-4xl font-semibold tracking-tight mb-3\" data-testid=\"privacy-heading\">Privacy Policy</h1><p class=\"text-sm mb-12\" style=\"color:rgba(255,255,255,0.3)\">Last updated: March 2026</p><div class=\"space-y-10\"><section><p style=\"color:rgba(255,255,255,0.55)\">missiAI is a voice AI assistant built with your privacy in mind. This policy explains what data we collect, how we use it, and what control you have over it. We keep things simple and transparent — no walls of legalese.</p></section><section><h2 class=\"text-lg font-medium tracking-tight mb-4 text-white\" data-testid=\"privacy-section-data-collected\">What data we collect</h2><div class=\"space-y-4\" style=\"color:rgba(255,255,255,0.5)\"><div><p class=\"font-medium text-white/70 mb-1\">Voice recordings</p><p>Your voice is sent to our speech-to-text service for real-time transcription. Audio is processed in-flight and is<!-- --> <strong class=\"text-white/70\">not stored</strong> on our servers after processing.</p></div><div><p class=\"font-medium text-white/70 mb-1\">Conversation text</p><p>The text of your conversations is held in your browser session only. It is sent to our AI service to generate responses but is not persisted on our servers beyond the active session.</p></div><div><p class=\"font-medium text-white/70 mb-1\">Memory facts</p><p>missiAI extracts key facts from your conversations (preferences, habits, context) and stores them in Cloudflare KV tied to your account. These memories power the personalized experience.</p></div><div><p class=\"font-medium text-white/70 mb-1\">Account information</p><p>We use Clerk for authentication. Clerk collects your email address and basic profile information when you sign up. We do not store passwords — Clerk handles authentication securely.</p></div></div></section><section><h2 class=\"text-lg font-medium tracking-tight mb-4 text-white\" data-testid=\"privacy-section-data-usage\">How we use your data</h2><p style=\"color:rgba(255,255,255,0.5)\">Your data is used exclusively to provide AI responses and memory features within missiAI. We do not sell, share, or monetize your personal data. We do not use your conversations to train AI models. Your data exists to make missi work better for<!-- --> <em>you</em> — nothing else.</p></section><section><h2 class=\"text-lg font-medium tracking-tight mb-4 text-white\" data-testid=\"privacy-section-third-party\">Third-party services</h2><p class=\"mb-4\" style=\"color:rgba(255,255,255,0.5)\">missiAI integrates with the following services to provide its functionality:</p><div class=\"rounded-xl overflow-hidden\" style=\"border:1px solid rgba(255,255,255,0.06)\"><div class=\"flex items-start gap-4 px-5 py-3.5 text-sm\" style=\"border-bottom:1px solid rgba(255,255,255,0.04);background:rgba(255,255,255,0.01)\"><span class=\"font-medium text-white/70 min-w-[140px]\">Google Gemini API</span><span style=\"color:rgba(255,255,255,0.45)\">AI chat responses and memory extraction</span></div><div class=\"flex items-start gap-4 px-5 py-3.5 text-sm\" style=\"border-bottom:1px solid rgba(255,255,255,0.04);background:transparent\"><span class=\"font-medium text-white/70 min-w-[140px]\">ElevenLabs</span><span style=\"color:rgba(255,255,255,0.45)\">Speech-to-text and text-to-speech</span></div><div class=\"flex items-start gap-4 px-5 py-3.5 text-sm\" style=\"border-bottom:none;background:rgba(255,255,255,0.01)\"><span class=\"font-medium text-white/70 min-w-[140px]\">Clerk</span><span style=\"color:rgba(255,255,255,0.45)\">User authentication and account management</span></div></div><p class=\"mt-4 text-sm\" style=\"color:rgba(255,255,255,0.35)\">Each service has its own privacy policy. We recommend reviewing them if you want full details on how they handle data.</p></section><section><h2 class=\"text-lg font-medium tracking-tight mb-4 text-white\" data-testid=\"privacy-section-retention\">Data retention</h2><p style=\"color:rgba(255,255,255,0.5)\">Memory facts are stored in Cloudflare KV and persist until you delete your account. Voice recordings are never stored. Conversation text exists only for the duration of your active browser session. Rate-limiting data and usage logs are retained temporarily for security purposes and automatically expire.</p></section><section><h2 class=\"text-lg font-medium tracking-tight mb-4 text-white\" data-testid=\"privacy-section-rights\">Your rights</h2><p style=\"color:rgba(255,255,255,0.5)\">You can delete all of your data at any time by deleting your account. This removes your memory facts from Cloudflare KV and your profile from Clerk. If you need assistance with data deletion, contact us at the email below.</p></section><section><h2 class=\"text-lg font-medium tracking-tight mb-4 text-white\" data-testid=\"privacy-section-contact\">Contact</h2><p style=\"color:rgba(255,255,255,0.5)\">For any privacy-related questions or data requests, reach out to us at<!-- --> <a href=\"mailto:rudrasatani@missi.space\" class=\"text-white/70 underline underline-offset-4 decoration-white/20 hover:decoration-white/40 transition-colors\" data-testid=\"privacy-contact-email\">rudrasatani@missi.space</a></p></section></div></div><!--$--><!--/$--></article></main></div><!--/$--></div><footer class=\"relative px-6 md:px-10 py-6\" style=\"border-top:1px solid rgba(255,255,255,0.04)\" data-testid=\"global-footer\"><div class=\"max-w-5xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-3\"><span class=\"text-[11px] font-light\" style=\"color:rgba(255,255,255,0.2)\">© <!-- -->2026<!-- --> missiAI</span><div class=\"flex items-center gap-5\"><a class=\"text-[11px] font-light transition-colors hover:text-white/50\" style=\"color:rgba(255,255,255,0.2)\" data-testid=\"footer-privacy-link\" href=\"/privacy\">Privacy Policy</a><a class=\"text-[11px] font-light transition-colors hover:text-white/50\" style=\"color:rgba(255,255,255,0.2)\" data-testid=\"footer-terms-link\" href=\"/terms\">Terms of Service</a><a href=\"https://github.com/rudrasatani13/missiAI\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"text-[11px] font-light transition-colors hover:text-white/50\" style=\"color:rgba(255,255,255,0.2)\" data-testid=\"footer-github-link\">GitHub</a></div></div></footer></div><section aria-label=\"Notifications alt+T\" tabindex=\"-1\" aria-live=\"polite\" aria-relevant=\"additions text\" aria-atomic=\"false\"></section><script src=\"/_next/static/chunks/webpack-9d34c7dae023d6dc.js\" id=\"_R_\" async=\"\"></script><script>(self.__next_f=self.__next_f||[]).push([0])</script><script>self.__next_f.push([1,\"1:\\\"$Sreact.fragment\\\"\\n2:I[46810,[\\\"6331\\\",\\\"static/chunks/6331-3bb9f5d3942f7e29.js\\\",\\\"2091\\\",\\\"static/chunks/2091-d7a598170f8c8af3.js\\\",\\\"4778\\\",\\\"static/chunks/4778-8df61705662411f2.js\\\",\\\"3018\\\",\\\"static/chunks/3018-b0c1fdbef98b950c.js\\\",\\\"1112\\\",\\\"static/chunks/1112-dd04eae3afe28e65.js\\\",\\\"7177\\\",\\\"static/chunks/app/layout-6d7dbc