# ─── Clerk Authentication ─────────────────────────────────────────────────────
# Get these from https://dashboard.clerk.com → API Keys
# Use test keys for development, live keys for production.
# PRODUCTION: Set via Cloudflare Pages dashboard (encrypted) or `wrangler secret put`
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxx

# Redirect URLs (safe to commit — no secrets)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/chat
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/chat

# ─── AI Providers ─────────────────────────────────────────────────────────────

# OpenAI (optional) — https://platform.openai.com/api-keys
# PRODUCTION: wrangler secret put OPENAI_API_KEY
OPENAI_API_KEY=

# Anthropic (optional) — https://console.anthropic.com/settings/keys
# PRODUCTION: wrangler secret put ANTHROPIC_API_KEY
ANTHROPIC_API_KEY=

# ─── Voice (ElevenLabs) ──────────────────────────────────────────────────────
# https://elevenlabs.io/app/settings/api-keys
# PRODUCTION: wrangler secret put ELEVENLABS_API_KEY
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ─── Payments (Dodo Payments) ─────────────────────────────────────────────────
# https://app.dodopayments.com — Developer > API
# PRODUCTION: wrangler secret put DODO_PAYMENTS_API_KEY  (and each key below)
DODO_PAYMENTS_API_KEY=
DODO_WEBHOOK_SECRET=
DODO_PRO_PRODUCT_ID=
DODO_BUSINESS_PRODUCT_ID=
# Set to "test_mode" for testing, "live_mode" for production
DODO_PAYMENTS_MODE=test_mode

# ─── Web Push (VAPID) ────────────────────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
# NEXT_PUBLIC_VAPID_PUBLIC_KEY is safe to commit (it's public)
# PRODUCTION: wrangler secret put VAPID_PRIVATE_KEY
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ─── Admin ────────────────────────────────────────────────────────────────────
# Your Clerk userId for the admin dashboard (from Clerk dashboard → Users)
# PRODUCTION: wrangler secret put ADMIN_USER_ID
ADMIN_USER_ID=

# ─── Budget ───────────────────────────────────────────────────────────────────
# Maximum daily AI spend in USD before budget alerts fire
DAILY_BUDGET_USD=5.0

# ─── App URL ──────────────────────────────────────────────────────────────────
# DEVELOPMENT: http://localhost:3000
# PRODUCTION:  https://missi.space  (set in wrangler.toml [vars], not here)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Google OAuth (Calendar Integration) ──────────────────────────────────────
# 1. Go to https://console.cloud.google.com → New Project
# 2. Enable "Google Calendar API"
# 3. OAuth Consent Screen → External
# 4. Credentials → Create → OAuth 2.0 Client ID → Web Application
# 5. Authorized redirect URI: http://localhost:3000/api/auth/callback/google
# PRODUCTION: wrangler secret put GOOGLE_CLIENT_ID (and GOOGLE_CLIENT_SECRET)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Notion OAuth (Notion Integration) ────────────────────────────────────────
# 1. Go to https://www.notion.so/my-integrations → New Integration
# 2. Set OAuth Redirect URI: http://localhost:3000/api/auth/callback/notion
# 3. Copy Client ID and Client Secret below
# PRODUCTION: wrangler secret put NOTION_CLIENT_ID (and NOTION_CLIENT_SECRET)
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
