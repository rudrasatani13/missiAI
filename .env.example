# ─────────────────────────────────────────────────────────────────────────────
# missiAI — Environment Variables Template
#
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local, .env.development.local, or .env.production.local.
# All *.local files are excluded via .gitignore.
#
# If any key below is accidentally committed, rotate it immediately:
#   Gemini:    console.cloud.google.com → Credentials → Delete + create new
#   ElevenLabs: elevenlabs.io → Profile → API Keys → Revoke + create new
#   Clerk:     clerk.com → API Keys → Rotate
#   Stripe:    dashboard.stripe.com → Developers → API Keys → Roll key
# ─────────────────────────────────────────────────────────────────────────────

NODE_VERSION=18

# ── AI (server-only — never prefix with NEXT_PUBLIC_) ────────────────────────
# Google Gemini API key. Get from: console.cloud.google.com → APIs → Gemini API
GEMINI_API_KEY=

# ── ElevenLabs (server-only) ─────────────────────────────────────────────────
# Get from: elevenlabs.io → Profile → API Keys
ELEVENLABS_API_KEY=
# Get from: elevenlabs.io → Voices → select a voice → copy Voice ID
ELEVENLABS_VOICE_ID=

# ── Clerk (split by environment) ─────────────────────────────────────────────
# Development keys go in .env.development.local
# Production keys go in .env.production.local  ← or Cloudflare Pages dashboard
# These are intentionally left blank here; use the correct env-specific file.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# ── Clerk redirect URLs ───────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/chat
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/chat
NEXT_PUBLIC_CLERK_WAITLIST_URL=/waitlist

# ── Stripe (server-only — never prefix with NEXT_PUBLIC_) ────────────────────
# Get from: dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=
# Get from: dashboard.stripe.com → Developers → Webhooks → select endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=
# Get from: dashboard.stripe.com → Products → select plan → copy Price ID
STRIPE_PRO_PRICE_ID=
STRIPE_BUSINESS_PRICE_ID=

# ── Admin ─────────────────────────────────────────────────────────────────────
# Clerk user ID of the admin account (used by /api/v1/admin/analytics)
# Get from: clerk.com → Users → select your account → copy User ID
ADMIN_USER_ID=

# ── Budget ────────────────────────────────────────────────────────────────────
# Daily AI spend alert threshold in USD. Server uses DAILY_BUDGET_USD (no prefix).
DAILY_BUDGET_USD=5.00
# Client-visible version (used by the dashboard UI only)
NEXT_PUBLIC_DAILY_BUDGET_USD=5.00

# ── App URL ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
