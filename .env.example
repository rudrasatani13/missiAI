# ─────────────────────────────────────────────────────────────────────────────
# missiAI — Environment Variables Template
#
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local, .env.development.local, or .env.production.local.
# All *.local files are excluded via .gitignore.
#
# If any key below is accidentally committed, rotate it immediately:
#   Gemini:    console.cloud.google.com → Credentials → Delete + create new
#   ElevenLabs: elevenlabs.io → Profile → API Keys → Revoke + create new
#   Clerk:     clerk.com → API Keys → Rotate
#   Dodo:      dashboard.dodopayments.com → API Keys → Rotate
# ─────────────────────────────────────────────────────────────────────────────

NODE_VERSION=18

# ── AI (server-only — never prefix with NEXT_PUBLIC_) ────────────────────────
GEMINI_API_KEY=

# ── ElevenLabs (server-only) ─────────────────────────────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ── Clerk (split by environment) ─────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# ── Clerk redirect URLs ───────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/chat
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/chat
NEXT_PUBLIC_CLERK_WAITLIST_URL=/waitlist

# ── Dodo Payments (server-only — never prefix with NEXT_PUBLIC_) ──────────────
DODO_API_KEY=
DODO_WEBHOOK_SECRET=
DODO_PRO_PRODUCT_ID=
DODO_BUSINESS_PRODUCT_ID=

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_USER_ID=

# ── Budget ────────────────────────────────────────────────────────────────────
DAILY_BUDGET_USD=5.00
NEXT_PUBLIC_DAILY_BUDGET_USD=5.00

# ── App URL ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://missi.space
