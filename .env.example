# ─── Clerk Authentication ─────────────────────────────────────────────────────
# Get these from https://dashboard.clerk.com → API Keys
# Use test keys for development, live keys for production.
# PRODUCTION: Set via Cloudflare dashboard (encrypted) or `wrangler secret put`
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxx

# Redirect URLs (safe to commit — no secrets)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/chat
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/chat

# ─── Vertex AI / Gemini (required) ───────────────────────────────────────────
# Use a service account JSON with access to Vertex AI.
# Keep the JSON on a single line when storing it in an env var.
# PRODUCTION: wrangler secret put GOOGLE_SERVICE_ACCOUNT_JSON
GOOGLE_SERVICE_ACCOUNT_JSON=
VERTEX_AI_PROJECT_ID=
VERTEX_AI_LOCATION=us-central1
AI_BACKEND=vertex

# ─── Optional Fallback Providers ──────────────────────────────────────────────

# OpenAI (optional) — https://platform.openai.com/api-keys
# PRODUCTION: wrangler secret put OPENAI_API_KEY
# Fallback is DISABLED by default. Set ENABLE_OPENAI_FALLBACK=true to allow
# automatic failover to OpenAI when Vertex is unavailable (higher cost).
OPENAI_API_KEY=
ENABLE_OPENAI_FALLBACK=false

# Anthropic (optional) — https://console.anthropic.com/settings/keys
# PRODUCTION: wrangler secret put ANTHROPIC_API_KEY
ANTHROPIC_API_KEY=

# ─── KV Encryption / Confirmation Tokens ──────────────────────────────────────
# Required in production for encrypted KV and live relay tickets.
# MINIMUM: 32 characters. Shorter values are REJECTED in production (fail closed).
# RECOMMENDED: 44+ chars with 256-bit entropy: openssl rand -base64 32
# Do NOT use a short passphrase or repeat characters.
# PRODUCTION: wrangler secret put MISSI_KV_ENCRYPTION_SECRET
MISSI_KV_ENCRYPTION_SECRET=

# ─── Guest Chat Session Signing ───────────────────────────────────────────────
# HMAC-SHA256 key for signing guest session cookies.
# Must be set in production — missing secret causes 503 (fail closed).
# Generate with: openssl rand -hex 32
# PRODUCTION: wrangler secret put GUEST_SESSION_SECRET
GUEST_SESSION_SECRET=

# ─── Guest Chat Limits ────────────────────────────────────────────────────────
# Per-IP max AI requests per 24h (in-isolate; not globally consistent).
GUEST_IP_DAILY_MAX=30
# Global max across all IPs per isolate lifetime (resets on isolate restart).
GUEST_GLOBAL_ISOLATE_MAX=500

# ─── App URL ──────────────────────────────────────────────────────────────────
# DEVELOPMENT: http://localhost:3000
# PRODUCTION:  https://missi.space  (set in wrangler.toml [vars], not here)
NEXT_PUBLIC_APP_URL=http://localhost:3000
