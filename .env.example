# ─── Clerk Authentication ─────────────────────────────────────────────────────
# Get these from https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxx

# ─── AI Providers ─────────────────────────────────────────────────────────────
# Google Gemini (required) — https://aistudio.google.com/apikey
GEMINI_API_KEY=

# OpenAI (optional) — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic (optional) — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ─── Voice (ElevenLabs) ──────────────────────────────────────────────────────
# https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ─── Payments (Razorpay) ─────────────────────────────────────────────────────
# https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PRO_PLAN_ID=
RAZORPAY_BUSINESS_PLAN_ID=

# ─── Web Push (VAPID) ────────────────────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ─── Admin ────────────────────────────────────────────────────────────────────
# Your Clerk userId for the admin dashboard
ADMIN_USER_ID=

# ─── Budget ───────────────────────────────────────────────────────────────────
DAILY_BUDGET_USD=5.0

# ─── App URL ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
